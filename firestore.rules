rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    match /school/{documentId} {
      allow get: if true;
      allow list: if true;
      // Due to the hardcoded unauthenticated admin system from previous version,
      // we allow writes. In a real environment, we'd enforce request.auth != null
      allow write: if true;
    }
  }
}
